  <script is:inline>
(function () {
  var root = document.querySelector('.boardstart-page');
  if (!root) return;

  // Get-started form — front-end only. Wire this to your endpoint (CRM / email / Calendly).
  root.querySelectorAll('.bs-form').forEach(function (f) {
    f.addEventListener('submit', function (e) {
      e.preventDefault();
      if (typeof f.checkValidity === 'function' && !f.checkValidity()) { f.reportValidity(); return; }
      var nameEl = f.querySelector('[name="name"]');
      var first = nameEl && nameEl.value ? nameEl.value.trim().split(' ')[0] : '';
      var msg = f.querySelector('.bs-form-msg');
      Array.prototype.forEach.call(f.children, function (c) {
        if (!c.classList.contains('bs-form-msg')) c.style.display = 'none';
      });
      if (msg) {
        msg.textContent = "Thanks" + (first ? ", " + first : "") + " — we'll reach out within one business day with the details.";
        msg.classList.add('show');
      }
    });
  });

  // Pricing tier -> preselect package in the hero form, then scroll up
  root.querySelectorAll('.t-cta[data-pkg]').forEach(function (a) {
    a.addEventListener('click', function () {
      var pkg = a.getAttribute('data-pkg');
      root.querySelectorAll('.bs-pkg').forEach(function (sel) {
        sel.value = pkg; sel.classList.add('bs-pkg-set');
      });
      setTimeout(function () {
        var input = root.querySelector('.bs-form input[name="name"]');
        if (input) { try { input.focus({ preventScroll: true }); } catch (e) {} }
      }, 650);
    });
  });

  // Header CTA — hidden until the hero form scrolls out of view above the
  // fold, then slides in from the right. Hides again if you scroll back up.
  var heroForm = root.querySelector('[data-variant-hero="' + (root.dataset.hero || 'outcome') + '"] .bs-form-card');
  var lpCta = document.querySelector('.bs-lp-cta');
  if (heroForm && lpCta) {
    if ('IntersectionObserver' in window) {
      var ctaIO = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          // Reveal only once the form has scrolled up past the top of the viewport.
          if (!e.isIntersecting && e.boundingClientRect.top < 0) {
            lpCta.classList.add('is-shown');
          } else if (e.isIntersecting) {
            lpCta.classList.remove('is-shown');
          }
        });
      }, { threshold: 0 });
      ctaIO.observe(heroForm);
    } else {
      lpCta.classList.add('is-shown');
    }
  }

  // FAQ accordion — ease open/close, and only one panel open at a time.
  var faq = root.querySelector('.bs-faq');
  if (faq) {
    var faqReduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var faqItems = Array.prototype.slice.call(faq.querySelectorAll('details'));
    faqItems.forEach(function (d) {
      var summary = d.querySelector('summary');
      if (!summary) return;
      // Wrap everything after the summary in an animatable body element.
      var body = document.createElement('div');
      body.className = 'bs-faq-body';
      while (summary.nextSibling) body.appendChild(summary.nextSibling);
      d.appendChild(body);
      if (d.open) d.classList.add('is-open');

      var animate = function (open) {
        if (d.classList.contains('bs-animating')) return;
        if (faqReduce) {                     // no motion: just toggle
          d.open = open;
          d.classList.toggle('is-open', open);
          body.style.height = '';
          return;
        }
        d.classList.add('bs-animating');
        if (open) {
          d.open = true;
          d.classList.add('is-open');
          var target = body.scrollHeight;
          body.style.height = '0px';
          requestAnimationFrame(function () { body.style.height = target + 'px'; });
        } else {
          d.classList.remove('is-open');
          body.style.height = body.scrollHeight + 'px';
          requestAnimationFrame(function () { body.style.height = '0px'; });
        }
        var done = function (ev) {
          if (ev.propertyName !== 'height') return;
          body.removeEventListener('transitionend', done);
          d.classList.remove('bs-animating');
          if (open) { body.style.height = 'auto'; }
          else { d.open = false; body.style.height = ''; }
        };
        body.addEventListener('transitionend', done);
      };

      summary.addEventListener('click', function (e) {
        e.preventDefault();
        if (d.open) { animate(false); return; }
        // Close any other open panel first (one at a time).
        faqItems.forEach(function (other) {
          if (other !== d && other.open) {
            var ob = other.querySelector('.bs-faq-body');
            other.classList.remove('is-open');
            if (faqReduce || !ob) { other.open = false; if (ob) ob.style.height = ''; }
            else {
              other.classList.add('bs-animating');
              ob.style.height = ob.scrollHeight + 'px';
              requestAnimationFrame(function () { ob.style.height = '0px'; });
              var oDone = function (ev) {
                if (ev.propertyName !== 'height') return;
                ob.removeEventListener('transitionend', oDone);
                other.open = false; ob.style.height = ''; other.classList.remove('bs-animating');
              };
              ob.addEventListener('transitionend', oDone);
            }
          }
        });
        animate(true);
      });
    });
  }

  // Momentum timeline — build the curve + draw it in on scroll
  var tl = root.querySelector('.bs-tl');
  if (tl) {
    var line = tl.querySelector('.bs-tl-line');
    var area = tl.querySelector('.bs-tl-area');
    var pts = [[100,213],[300,188],[500,150],[700,108],[900,62],[1100,20]];
    var d = 'M' + pts[0][0] + ' ' + pts[0][1];
    for (var i = 0; i < pts.length - 1; i++) {
      var p0 = pts[i-1] || pts[i], p1 = pts[i], p2 = pts[i+1], p3 = pts[i+2] || p2;
      d += ' C' + (p1[0]+(p2[0]-p0[0])/6) + ' ' + (p1[1]+(p2[1]-p0[1])/6) + ' ' +
                  (p2[0]-(p3[0]-p1[0])/6) + ' ' + (p2[1]-(p3[1]-p1[1])/6) + ' ' + p2[0] + ' ' + p2[1];
    }
    line.setAttribute('d', d);
    area.setAttribute('d', d + ' L1100 248 L100 248 Z');
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var len = line.getTotalLength ? line.getTotalLength() : 0;
    if (!reduce && len) { line.style.strokeDasharray = len; line.style.strokeDashoffset = len; }
    var go = function () {
      tl.classList.add('in');
      if (!reduce && len) {
        line.style.transition = 'stroke-dashoffset 1700ms cubic-bezier(0.16,1,0.3,1)';
        requestAnimationFrame(function () { line.style.strokeDashoffset = '0'; });
      }
    };
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (es) {
        es.forEach(function (e) { if (e.isIntersecting) { go(); io.disconnect(); } });
      }, { threshold: 0.25 });
      io.observe(tl);
    } else { go(); }
  }
})();
  </script>
</BaseLayout>
