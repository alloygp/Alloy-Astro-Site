---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Knowledge Check — Building Trust as a CAM | Alloy Growth Partners"
  description="Test your understanding of trust-building principles for community association managers."
  pageId="resources"
>
<div class="course-page">


<header class="topbar">
  <div class="topbar-left">
    <div class="topbar-brand">Alloy<span class="dot">.</span></div>
    <a class="topbar-back" href="/courses/trust-building">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
      Trust-Building for CAM Firms
    </a>
  </div>
  <div class="topbar-progress">
    <span>10 / 10</span>
    <div class="topbar-progress-bar"><div class="topbar-progress-fill"></div></div>
    <span>90%</span>
  </div>
</header>

<div class="shell">

  <!-- Sidebar (compressed — same structure, all lessons done, quiz active) -->
  <aside class="sidebar">
    <div class="sidebar-head">
      <div class="sidebar-eyebrow">Building Trust</div>
      <div class="sidebar-title">Trust-Building for CAM Firms</div>
      <div class="sidebar-meta">10 lessons · 1 quiz · <strong>90% complete</strong></div>
    </div>

    <div class="module-block" style="--module-color: #381c4f">
      <div class="module-label">Module 1 · Introduction</div>
      <a class="lesson-row done" href="/courses/trust-building-lesson"><div class="lesson-check">✓</div><div class="lesson-text">Intro to <em>Trust-Building for CAM Firms</em><small>4 min · Lesson</small></div></a>
      <a class="lesson-row done" href="/courses/trust-building-lesson"><div class="lesson-check">✓</div><div class="lesson-text">Why trust signals matter to HOA boards<small>6 min · Lesson</small></div></a>
    </div>
    <div class="module-block" style="--module-color: #d9356e">
      <div class="module-label">Module 2 · Reviews</div>
      <a class="lesson-row done" href="#"><div class="lesson-check">✓</div><div class="lesson-text">What reviews are and why they carry weight<small>7 min · Lesson</small></div></a>
      <a class="lesson-row done" href="#"><div class="lesson-check">✓</div><div class="lesson-text">Reviews: extra factors that influence impact<small>5 min · Lesson</small></div></a>
    </div>
    <div class="module-block" style="--module-color: #f5d880">
      <div class="module-label">Module 3 · Testimonials</div>
      <a class="lesson-row done" href="#"><div class="lesson-check">✓</div><div class="lesson-text">What testimonials are and why they stand out<small>6 min · Lesson</small></div></a>
      <a class="lesson-row done" href="#"><div class="lesson-check">✓</div><div class="lesson-text">Testimonials: extra factors that influence impact<small>5 min · Lesson</small></div></a>
    </div>
    <div class="module-block" style="--module-color: #aed7d0">
      <div class="module-label">Module 4 · Case studies</div>
      <a class="lesson-row done" href="#"><div class="lesson-check">✓</div><div class="lesson-text">What case studies are and why they convince<small>7 min · Lesson</small></div></a>
      <a class="lesson-row done" href="#"><div class="lesson-check">✓</div><div class="lesson-text">Case studies: extra factors that influence impact<small>6 min · Lesson</small></div></a>
    </div>
    <div class="module-block" style="--module-color: #381c4f">
      <div class="module-label">Module 5 · Wrap-up</div>
      <a class="lesson-row done" href="#"><div class="lesson-check">✓</div><div class="lesson-text">Recapping the 3 trust signals<small>4 min · Lesson</small></div></a>
      <a class="lesson-row done" href="#"><div class="lesson-check">✓</div><div class="lesson-text">From proof to persuasion<small>6 min · Lesson</small></div></a>
      <a class="lesson-row active" href="#"><div class="lesson-check">★</div><div class="lesson-text">Check your learning<small>5 min · Quiz</small></div></a>
    </div>
  </aside>

  <!-- Main -->
  <main class="main" id="quizMain">
    <div class="crumbs">
      <a href="/courses">Courses</a>
      <span class="sep">/</span>
      <a href="/courses/trust-building">Trust-Building for CAM Firms</a>
      <span class="sep">/</span>
      <span class="here">Knowledge check</span>
    </div>

    <div class="quiz-counter">Final knowledge check</div>
    <h1 class="quiz-h1">Check your learning.</h1>
    <p class="quiz-sub">Five questions on what you covered. Pass at 70%+. You can retake it as many times as you want.</p>
    <div class="quiz-meta">
      <span class="quiz-meta-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        ~5 minutes
      </span>
      <span class="quiz-meta-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M12 22a10 10 0 1 0-10-10"/></svg>
        5 questions · multiple choice
      </span>
      <span class="quiz-meta-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 11.08 22 12 a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Pass at 70%+
      </span>
    </div>

    <!-- Result banner (revealed after submit) -->
    <div class="result-banner" id="resultBanner">
      <div class="result-banner-grid">
        <div>
          <div class="result-eyebrow">Quiz complete</div>
          <h2 class="result-headline" id="resultHeadline">Nicely done — you passed.</h2>
          <p class="result-sub" id="resultSub">You got <strong id="resultFrac">4 of 5</strong> right. Review the one you missed below — it's the difference between picking the right signal and picking the comfortable one.</p>
        </div>
        <div class="score-ring" id="scoreRing">
          <div class="score-ring-inner">
            <div class="score-ring-pct" id="scorePct">80%</div>
            <div class="score-ring-frac">Score</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Q1 -->
    <div class="question" data-q="1">
      <div class="q-num">Question 1 of 5 <span class="q-status correct">Correct</span></div>
      <div class="q-prompt">Which trust signal is most useful <strong>before</strong> a board has reached out to your firm?</div>
      <div class="options">
        <label class="option" data-correct="true" data-letter="A">
          <input type="radio" name="q1" />
          <span class="option-bullet"></span>
          <span class="option-text"><strong>Reviews</strong> — volume, recency, and homeowner voices</span>
          <span class="option-marker">Correct answer</span>
        </label>
        <label class="option" data-letter="B">
          <input type="radio" name="q1" />
          <span class="option-bullet"></span>
          <span class="option-text">Testimonials from named board presidents</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-letter="C">
          <input type="radio" name="q1" />
          <span class="option-bullet"></span>
          <span class="option-text">A detailed case study with measurable outcomes</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-letter="D">
          <input type="radio" name="q1" />
          <span class="option-bullet"></span>
          <span class="option-text">An industry award or certification</span>
          <span class="option-marker">Your answer</span>
        </label>
      </div>
      <div class="explanation">
        <strong>Why:</strong> Reviews are the discovery-stage signal. Boards looking at firms they haven't contacted yet check reviews to confirm you're active and well-regarded. Testimonials and case studies become more important <em>after</em> they're already considering you.
      </div>
    </div>

    <!-- Q2 -->
    <div class="question" data-q="2">
      <div class="q-num">Question 2 of 5 <span class="q-status correct">Correct</span></div>
      <div class="q-prompt">What primarily makes a testimonial more impactful than a review?</div>
      <div class="options">
        <label class="option" data-letter="A">
          <input type="radio" name="q2" />
          <span class="option-bullet"></span>
          <span class="option-text">It's longer than a review</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-letter="B">
          <input type="radio" name="q2" />
          <span class="option-bullet"></span>
          <span class="option-text">It includes a star rating</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-correct="true" data-letter="C">
          <input type="radio" name="q2" />
          <span class="option-bullet"></span>
          <span class="option-text"><strong>Specificity and a named author</strong> — a real board member saying something concrete</span>
          <span class="option-marker">Correct answer</span>
        </label>
        <label class="option" data-letter="D">
          <input type="radio" name="q2" />
          <span class="option-bullet"></span>
          <span class="option-text">It was published more recently</span>
          <span class="option-marker">Your answer</span>
        </label>
      </div>
      <div class="explanation">
        <strong>Why:</strong> Testimonials work because they put a face and a name on the proof. Anonymous or generic praise reads as filler. The more specific the person, role, and outcome, the more weight a board gives it.
      </div>
    </div>

    <!-- Q3 -->
    <div class="question" data-q="3">
      <div class="q-num">Question 3 of 5 <span class="q-status wrong">Try again</span></div>
      <div class="q-prompt">A board is in the final round, comparing you against two other firms. Which signal carries the most weight?</div>
      <div class="options">
        <label class="option" data-letter="A">
          <input type="radio" name="q3" />
          <span class="option-bullet"></span>
          <span class="option-text">Reviews — overall star average</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-letter="B">
          <input type="radio" name="q3" />
          <span class="option-bullet"></span>
          <span class="option-text">Testimonials from past board members</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-correct="true" data-letter="C">
          <input type="radio" name="q3" />
          <span class="option-bullet"></span>
          <span class="option-text"><strong>Case studies</strong> — a community like theirs, a measurable outcome</span>
          <span class="option-marker">Correct answer</span>
        </label>
        <label class="option" data-letter="D">
          <input type="radio" name="q3" />
          <span class="option-bullet"></span>
          <span class="option-text">Brand awareness in the metro area</span>
          <span class="option-marker">Your answer</span>
        </label>
      </div>
      <div class="explanation">
        <strong>Why:</strong> By the final round, the board has already decided you're credible. They're now de-risking the choice — and case studies do that better than anything else. A community like theirs, a problem like theirs, a result they can point to in their vote.
      </div>
    </div>

    <!-- Q4 -->
    <div class="question" data-q="4">
      <div class="q-num">Question 4 of 5 <span class="q-status correct">Correct</span></div>
      <div class="q-prompt">Which is <strong>not</strong> one of the three primary trust signals covered in this course?</div>
      <div class="options">
        <label class="option" data-letter="A">
          <input type="radio" name="q4" />
          <span class="option-bullet"></span>
          <span class="option-text">Reviews</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-letter="B">
          <input type="radio" name="q4" />
          <span class="option-bullet"></span>
          <span class="option-text">Testimonials</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-letter="C">
          <input type="radio" name="q4" />
          <span class="option-bullet"></span>
          <span class="option-text">Case studies</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-correct="true" data-letter="D">
          <input type="radio" name="q4" />
          <span class="option-bullet"></span>
          <span class="option-text"><strong>Press mentions</strong></span>
          <span class="option-marker">Correct answer</span>
        </label>
      </div>
      <div class="explanation">
        <strong>Why:</strong> Press mentions can support credibility, but they're not the load-bearing trust signals for board decisions. Reviews, testimonials, and case studies are.
      </div>
    </div>

    <!-- Q5 -->
    <div class="question" data-q="5">
      <div class="q-num">Question 5 of 5 <span class="q-status correct">Correct</span></div>
      <div class="q-prompt">True or false: showing the same trust signal at every stage of the board journey is the strongest approach.</div>
      <div class="options">
        <label class="option" data-letter="A">
          <input type="radio" name="q5" />
          <span class="option-bullet"></span>
          <span class="option-text">True</span>
          <span class="option-marker">Your answer</span>
        </label>
        <label class="option" data-correct="true" data-letter="B">
          <input type="radio" name="q5" />
          <span class="option-bullet"></span>
          <span class="option-text"><strong>False</strong> — different signals carry different weight at different stages</span>
          <span class="option-marker">Correct answer</span>
        </label>
      </div>
      <div class="explanation">
        <strong>Why:</strong> Each signal has a job. Reviews build initial credibility, testimonials reassure during consideration, case studies de-risk the final vote. Use them in that order — not all at once.
      </div>
    </div>

    <!-- Pre-grade submit row -->
    <div class="submit-row">
      <div class="submit-status" id="submitStatus">0 of 5 answered</div>
      <button class="btn btn-primary" id="submitBtn" disabled>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Submit answers
      </button>
    </div>

    <!-- Post-grade actions -->
    <div class="post-actions">
      <div class="completion-card">
        <h3>You finished the course. ★</h3>
        <p>You've completed Trust-Building for CAM Firms. The next step in the Building Trust track is "Putting Trust Signals to Work" — practical templates for collecting, displaying, and refreshing your three signals.</p>
      </div>
      <div class="post-cta-row">
        <a href="#" class="btn btn-secondary">Continue to next course →</a>
        <button class="btn btn-ghost" id="retakeBtn">↺ Retake the quiz</button>
      </div>
    </div>

  </main>
</div>

<script>
  // For demo: clicking Submit applies a pre-set answer pattern (4/5 correct — Q3 wrong)
  // so reviewers can see the graded state without actually answering.
  const main = document.getElementById('quizMain');
  const submitBtn = document.getElementById('submitBtn');
  const submitStatus = document.getElementById('submitStatus');
  const resultBanner = document.getElementById('resultBanner');
  const retakeBtn = document.getElementById('retakeBtn');

  // Pre-set "user answers" for the demo
  const demoAnswers = { q1: 'A', q2: 'C', q3: 'B', q4: 'D', q5: 'B' };
  // q3 is wrong (correct is C) — so 4/5

  function answeredCount() {
    return Object.keys(demoAnswers).filter(name => {
      const checked = document.querySelector(`input[name="${name}"]:checked`);
      return !!checked;
    }).length;
  }
  function updateStatus() {
    const n = answeredCount();
    submitStatus.textContent = `${n} of 5 answered`;
    submitBtn.disabled = n < 5;
  }
  document.querySelectorAll('input[type="radio"]').forEach(r => r.addEventListener('change', updateStatus));

  // For convenience: enable submit immediately so demo works without clicking
  submitBtn.disabled = false;
  submitStatus.textContent = 'Demo: click submit to grade';

  submitBtn.addEventListener('click', () => {
    // Apply demo answers
    Object.entries(demoAnswers).forEach(([name, letter]) => {
      const opts = document.querySelectorAll(`input[name="${name}"]`);
      const labels = document.querySelectorAll(`label.option`);
      // pick the option in this question with matching data-letter
      document.querySelectorAll(`.question`).forEach(qEl => {
        if (qEl.querySelector(`input[name="${name}"]`)) {
          const target = qEl.querySelector(`label[data-letter="${letter}"] input`);
          if (target) target.checked = true;
        }
      });
    });

    // Mark each question with correct/wrong styling
    document.querySelectorAll('.question').forEach(qEl => {
      const correctOpt = qEl.querySelector('label[data-correct="true"]');
      const checkedInput = qEl.querySelector('input:checked');
      const checkedOpt = checkedInput ? checkedInput.closest('label.option') : null;

      // Always highlight the correct answer
      if (correctOpt) correctOpt.classList.add('correct');
      // If user picked something different, mark theirs wrong
      if (checkedOpt && checkedOpt !== correctOpt) {
        checkedOpt.classList.add('wrong');
      }
    });

    main.classList.add('graded');
    resultBanner.classList.add('show');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  retakeBtn.addEventListener('click', () => {
    main.classList.remove('graded');
    resultBanner.classList.remove('show');
    document.querySelectorAll('.option').forEach(o => o.classList.remove('correct', 'wrong'));
    document.querySelectorAll('input[type="radio"]').forEach(r => r.checked = false);
    submitStatus.textContent = 'Demo: click submit to grade';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>


</div>
</BaseLayout>

<style>
/* ---------- Top bar (match lesson view) ---------- */
  .topbar {
    background: #fff;
    border-bottom: 1px solid var(--border-subtle);
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }
  .topbar-left { display: flex; align-items: center; gap: 24px; }
  .topbar-brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 18px;
    color: var(--alloy-purple);
    letter-spacing: -0.01em;
  }
  .topbar-brand .dot { color: var(--alloy-pink); }
  .topbar-back {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    color: var(--alloy-purple);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .topbar-back:hover { color: var(--alloy-pink); }
  .topbar-progress {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 12px;
    color: var(--alloy-purple);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .topbar-progress-bar {
    width: 180px;
    height: 6px;
    background: var(--alloy-purple-tint);
    border-radius: 999px;
    overflow: hidden;
  }
  .topbar-progress-fill {
    height: 100%;
    width: 90%;
    background: linear-gradient(90deg, var(--alloy-pink), #c12a60);
    border-radius: 999px;
    transition: width 0.3s var(--ease-standard);
  }

  /* ---------- Layout shell (match lesson view) ---------- */
  .shell {
    display: grid;
    grid-template-columns: 380px 1fr;
    min-height: calc(100vh - 76px);
  }

  /* ---------- Sidebar (compressed reuse of lesson view) ---------- */
  .sidebar {
    background: #fff;
    border-right: 1px solid var(--border-subtle);
    padding: 28px 0 80px;
    overflow-y: auto;
    position: sticky;
    top: 76px;
    height: calc(100vh - 76px);
  }
  .sidebar-head {
    padding: 0 28px 22px;
    border-bottom: 1px solid var(--border-subtle);
    margin-bottom: 12px;
  }
  .sidebar-eyebrow {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--alloy-pink);
    margin-bottom: 8px;
  }
  .sidebar-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 19px;
    line-height: 1.25;
    color: var(--alloy-purple);
    letter-spacing: -0.01em;
  }
  .sidebar-meta {
    font-family: var(--font-display);
    font-size: 13px;
    color: var(--fg-muted);
    margin-top: 10px;
    font-weight: 500;
  }
  .sidebar-meta strong { color: var(--alloy-pink); font-weight: 700; }

  .module-block { margin-bottom: 4px; }
  .module-label {
    padding: 16px 28px 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-muted);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .module-label::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--module-color, var(--alloy-purple));
  }
  .lesson-row {
    display: grid;
    grid-template-columns: 26px 1fr;
    gap: 14px;
    align-items: flex-start;
    padding: 12px 28px;
    text-decoration: none;
    color: var(--alloy-purple);
    font-size: 15px;
    line-height: 1.45;
    border-left: 3px solid transparent;
    transition: all 0.15s;
  }
  .lesson-row:hover { background: var(--alloy-off-white); color: var(--alloy-pink); }
  .lesson-row.active {
    background: var(--alloy-pink-tint);
    border-left-color: var(--alloy-pink);
    color: var(--alloy-pink);
    font-weight: 600;
  }
  .lesson-row.active .lesson-check { background: var(--alloy-pink); border-color: var(--alloy-pink); color: #fff; }
  .lesson-row.done { color: #777; }
  .lesson-row.done .lesson-check {
    background: var(--alloy-green);
    border-color: var(--alloy-green);
    color: var(--alloy-purple);
  }
  .lesson-check {
    width: 26px;
    height: 26px;
    border-radius: 999px;
    border: 1.5px solid #d8d2e0;
    background: #fff;
    flex-shrink: 0;
    margin-top: 1px;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 12px;
    color: #aaa;
  }
  .lesson-row .lesson-text { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .lesson-row .lesson-text small {
    font-size: 12px;
    color: var(--fg-muted);
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ---------- Main ---------- */
  .main {
    padding: 56px 80px 120px;
    max-width: 880px;
    margin: 0 auto;
    width: 100%;
  }
  .crumbs {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 18px;
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .crumbs a { color: var(--fg-muted); }
  .crumbs a:hover { color: var(--alloy-pink); }
  .crumbs .sep { color: #d0c8db; }
  .crumbs .here { color: var(--alloy-purple); }

  .quiz-counter {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--alloy-yellow);
    margin-bottom: 10px;
  }
  .quiz-counter::before {
