---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CourseTrustBuildingLessonPage from '../../../../components/pages/CourseTrustBuildingLessonPage';
import { getLessonBySlug } from '../../../../data/courseTrustBuilding';

const { slug } = Astro.params;
const lesson = slug ? getLessonBySlug(slug) : undefined;

if (!lesson) {
  return Astro.redirect('/courses/trust-building', 302);
}
---
<BaseLayout
  title={lesson.metaTitle}
  description={lesson.metaDescription}
  pageId="resources"
>
  <CourseTrustBuildingLessonPage lessonSlug={lesson.slug} client:load />
</BaseLayout>
