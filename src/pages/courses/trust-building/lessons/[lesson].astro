---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CourseTrustBuildingLessonPage from '~/components/pages/CourseTrustBuildingLessonPage';
import { getLessonBySlug } from '~/data/courseTrustBuilding';
import '~/styles/courses.css';

const { lesson } = Astro.params;
const lessonData = lesson ? getLessonBySlug(lesson) : undefined;

if (!lessonData) {
  return Astro.redirect('/courses/trust-building', 302);
}
---
<BaseLayout
  title={lessonData.metaTitle}
  description={lessonData.metaDescription}
  pageId="resources"
  hideHeader={true}
>
  <CourseTrustBuildingLessonPage lessonSlug={lessonData.slug} client:load />
</BaseLayout>
