<script>
  // Tiny interaction so the demo feels real
  document.getElementById('completeBtn')?.addEventListener('click', (e) => {
    e.preventDefault();
    const fill = document.querySelector('.topbar-progress-fill');
    if (fill) fill.style.width = '30%';
    const counter = document.querySelector('.topbar-progress span');
    if (counter) counter.textContent = '3 / 10';
    const pct = document.querySelectorAll('.topbar-progress span')[1];
    if (pct) pct.textContent = '30%';

    // Mark current as done, advance active
    const rows = document.querySelectorAll('.lesson-row');
    const current = document.querySelector('.lesson-row.active');
    if (current) {
      current.classList.remove('active');
      current.classList.add('done');
      current.querySelector('.lesson-check').textContent = '✓';
      // find next
      const idx = [...rows].indexOf(current);
      const next = rows[idx + 1];
      if (next) {
        next.classList.add('active');
      }
    }
  });
</script>


</div>
</BaseLayout>

