---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CourseTrustBuildingPage from '~/components/pages/CourseTrustBuildingPage';

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Trust Building for CAM Firms: Reviews, Testimonials & Case Studies',
  description: 'Learn how reviews, testimonials, and case studies help CAM companies win more boards. Free micro-course from Alloy Growth Partners.',
  url: 'https://alloygp.co/resources/courses/trust-building',
  provider: {
    '@type': 'Organization',
    name: 'Alloy Growth Partners',
    url: 'https://alloygp.co',
  },
  educationalLevel: 'Beginner',
  inLanguage: 'en',
  isAccessibleForFree: true,
  courseMode: 'online',
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    instructor: {
      '@type': 'Organization',
      name: 'Alloy Growth Partners',
      url: 'https://alloygp.co',
    },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://alloygp.co',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Resources',
      item: 'https://alloygp.co/resources',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Courses',
      item: 'https://alloygp.co/resources/courses',
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: 'Trust Building for CAM Firms',
      item: 'https://alloygp.co/resources/courses/trust-building',
    },
  ],
};
---
<BaseLayout
  title="Trust Building for CAM Firms | Alloy Courses"
  description="Learn how reviews, testimonials, and case studies help CAM companies win more boards. Free micro-course from Alloy Growth Partners."
  pageId="resources"
  pageSchema={[courseSchema, breadcrumbSchema]}
>
  <CourseTrustBuildingPage client:idle />
</BaseLayout>
