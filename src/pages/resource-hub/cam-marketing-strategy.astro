---
import BaseLayout from '~/layouts/BaseLayout.astro';
import MarketingStrategyArticle from '~/components/pages/MarketingStrategyArticle';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'The CAM Marketing Strategy That Actually Compounds',
  description: "Why 'do more marketing' fails and what an engineered, system-first growth strategy looks like for CAM firms over 18 months.",
  url: 'https://alloygp.co/resource-hub/cam-marketing-strategy',
  mainEntityOfPage: 'https://alloygp.co/resource-hub/cam-marketing-strategy',
  author: {
    '@type': 'Person',
    name: 'Skyler Nelson',
    jobTitle: 'Managing Partner',
    worksFor: {
      '@type': 'Organization',
      name: 'Alloy Growth Partners',
      url: 'https://alloygp.co',
    },
  },
  publisher: {
    '@type': 'Organization',
    name: 'Alloy Growth Partners',
    url: 'https://alloygp.co',
    logo: {
      '@type': 'ImageObject',
      url: 'https://alloygp.co/assets/alloy-logo-full-color.svg',
    },
  },
  image: 'https://alloygp.co/assets/alloy-og.png',
};
---
<BaseLayout
  title="The CAM Marketing Strategy That Actually Compounds — Alloy"
  description="Why 'do more marketing' fails and what an engineered, system-first growth strategy looks like for CAM firms over 18 months."
  pageId="resources"
  ogType="article"
  pageSchema={articleSchema}
>
  <MarketingStrategyArticle client:idle />
</BaseLayout>
