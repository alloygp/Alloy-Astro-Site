---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroStatic from '~/components/sections/HeroStatic.astro';
import HomePage from '~/components/pages/HomePage';
---
<BaseLayout
  title="Alloy — One growth partner. Three engines. Exclusively CAM."
  description="Alloy engineers growth for CAM firms through three connected engines — BoardReach, BoardMatch, BoardRetain — run as one playbook with market exclusivity."
  pageId="home"
  animatedBar={true}
>
  <!--
    HeroStatic renders the homepage h1 as pure static HTML — no React island,
    no hydration wrapper. Chrome records LCP at HTML parse time (~0 ms element
    render delay) instead of at React's requestIdleCallback (~2,450 ms).
    HomePagecomponent receives hideHero=true so it skips the duplicate Hero.
  -->
  <HeroStatic />
  <HomePage client:idle hideHero={true} />
</BaseLayout>
