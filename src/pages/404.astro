---
// 404 page. Mirrors NotFoundPage from app.jsx.
import BaseLayout from '~/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page not found — Alloy Growth Partners"
  description="That page wandered off. Here's a way back to Alloy."
>
  <section class="notfound-section">
    <div class="notfound-wrap">
      <div class="notfound-code">404</div>
      <h1 class="display-lg notfound-h1">That page wandered off.</h1>
      <p class="lead notfound-p">It might have moved, or it might never have existed. Either way, here's a way back.</p>
      <div class="notfound-actions">
        <a href="/" class="btn btn-primary btn-arrow">Back to home</a>
        <a href="/services" class="btn btn-secondary">See our services</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound-section {
    min-height: 60vh;
    display: grid;
    place-items: center;
    padding: 120px 32px;
    background: #fff;
  }
  .notfound-wrap {
    text-align: center;
    max-width: 600px;
  }
  .notfound-code {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 96px;
    color: var(--alloy-pink);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .notfound-h1 {
    color: var(--alloy-purple);
    margin: 12px 0 14px;
  }
  .notfound-p {
    margin-bottom: 28px;
  }
  .notfound-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
