---
// src/layouts/BaseLayout.astro
// Single layout for every Alloy page. All SEO defaults pulled from
// src/config/site.ts — never hardcode site name, OG image path, or
// twitter handle in page files.
//
// Usage (minimal):
//   <BaseLayout title="…" description="…" pageId="services">
//     …page sections…
//   </BaseLayout>
//
// Usage (article with custom OG image + schema):
//   <BaseLayout
//     title="…"
//     description="…"
//     pageId="resources"
//     ogType="article"
//     ogImage="/assets/og/my-article.png"
//     pageSchema={articleSchema}
//   >
//     …
//   </BaseLayout>
//
// Usage (noindex):
//   <BaseLayout title="…" description="…" robots="noindex,nofollow">

import '../styles/colors_and_type.css';
import '../styles/site.css';
import '../styles/chrome.css';
import '../styles/mobile.css';

import SpeedInsights from '@vercel/speed-insights/astro';
import SiteHeader from '../components/chrome/SiteHeader.tsx';
import SiteFooter from '../components/chrome/SiteFooter.tsx';
import { SITE } from '../config/site.ts';

interface Props {
  /** <title> tag. Keep ≤ 60 chars for clean SERP display. Required. */
  title: string;

  /** Meta description. Keep 120–160 chars. Required. */
  description: string;

  /**
   * Which top-level nav item highlights as active.
   * Values: home | about | services | boardsuite | approach | resources
   * Pass null/undefined to leave nothing highlighted.
   */
  pageId?: string | null;

  /**
   * Header visual theme. Defaults to 'light'.
   * Use 'purple' on interior pages whose hero starts on a light background.
   */
  headerTheme?: 'light' | 'purple';

  /**
   * Disable the animated 5-color accent bar at the top of the footer.
   * Defaults to true (enabled).
   */
  animatedBar?: boolean;

  /**
   * Hide the global SiteHeader entirely (e.g. course lesson/quiz pages
   * that ship their own contextual topbar).
   */
  hideHeader?: boolean;

  /**
   * og:type. Defaults to 'website'. Use 'article' for resource hub articles.
   */
  ogType?: 'website' | 'article';

  /**
   * Per-page OG image. Absolute path from /public, e.g. "/assets/og/my-page.png".
   * Defaults to SITE.defaultOgImage (/assets/alloy-og.png).
   * Image must be 1200×630px PNG.
   */
  ogImage?: string;

  /**
   * robots meta content. Omit entirely for normal indexed pages.
   * Use "noindex,nofollow" for thank-you pages, staging, legal utilities, etc.
   * Use "noindex,follow" to allow link-following without indexing.
   */
  robots?: string;

  /**
   * Page-specific JSON-LD schema object(s) injected alongside the base
   * Organization schema. Pass a single object or an array.
   * E.g. FAQPage schema, Article schema, Service schema.
   */
  pageSchema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  pageId = null,
  headerTheme = 'light',
  animatedBar = true,
  hideHeader = false,
  ogType = 'website',
  ogImage: ogImageProp,
  robots,
  pageSchema,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? SITE.url).toString();

// Resolve OG image to absolute URL — use page override if provided, else default
const resolvedOgImage = new URL(
  ogImageProp ?? SITE.defaultOgImage,
  Astro.site ?? SITE.url
).toString();

const orgLd = {
  '@context': 'https://schema.org',
  '@type': SITE.org.type,
  name: SITE.name,
  url: SITE.url,
  logo: SITE.org.logo,
  description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.org.addressLocality,
    addressRegion: SITE.org.addressRegion,
    addressCountry: SITE.org.addressCountry,
  },
  telephone: SITE.org.telephone,
  email: SITE.org.email,
  areaServed: SITE.org.areaServed,
  priceRange: SITE.org.priceRange,
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/assets/alloy-icon-1500.png" />

    <!-- Robots (only emitted when explicitly set — absence = index,follow) -->
    {robots && <meta name="robots" content={robots} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={SITE.ogImageWidth} />
    <meta property="og:image:height" content={SITE.ogImageHeight} />
    <meta property="og:image:alt" content={`${SITE.name} — The growth system for CAM companies`} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content={`${SITE.name} — The growth system for CAM companies`} />

    <!-- Fonts: preload the two most-used Gotham weights — download starts with HTML parse, not after CSS -->
    <!-- WOFF2 is ~30% smaller than OTF; OTF is the fallback for any browser that needs it (none in 2026) -->
    <link rel="preload" href="/fonts/Gotham-Book.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Gotham-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <!-- No Google Fonts: Manrope/Sora unused in CSS; Gotham is self-hosted; system fonts cover the swap period -->

    <!-- Critical CSS — inlined so the LCP element (h1.display-xxl in the hero) can paint before the
         CSS bundle arrives. Covers: CSS vars, body baseline, has-fixed-header offset, hero layout,
         display type scale, eyebrow, lead. The full CSS bundle still loads and takes over — no duplication issues.
         @font-face declarations also included so preloaded WOFF2s connect to "Gotham" immediately. -->
    <style>
      /* @font-face — must come before any font-family references */
      @font-face{font-family:"Gotham";font-weight:300;font-style:normal;font-display:swap;src:url("/fonts/Gotham-Light.woff2") format("woff2"),url("/fonts/Gotham-Light.otf") format("opentype")}
      @font-face{font-family:"Gotham";font-weight:400;font-style:normal;font-display:swap;src:url("/fonts/Gotham-Book.woff2") format("woff2"),url("/fonts/Gotham-Book.otf") format("opentype")}
      @font-face{font-family:"Gotham";font-weight:500;font-style:normal;font-display:swap;src:url("/fonts/Gotham-Medium.woff2") format("woff2"),url("/fonts/Gotham-Medium.otf") format("opentype")}
      @font-face{font-family:"Gotham";font-weight:700;font-style:normal;font-display:swap;src:url("/fonts/Gotham-Bold.woff2") format("woff2"),url("/fonts/Gotham-Bold.otf") format("opentype")}
      @font-face{font-family:"Gotham";font-weight:800;font-style:normal;font-display:swap;src:url("/fonts/Gotham-Black.woff2") format("woff2"),url("/fonts/Gotham-Black.otf") format("opentype")}
      @font-face{font-family:"Gotham";font-weight:900;font-style:normal;font-display:swap;src:url("/fonts/Gotham-Ultra.woff2") format("woff2"),url("/fonts/Gotham-Ultra.otf") format("opentype")}
      /* CSS custom properties — only what above-the-fold elements reference */
      :root{--alloy-purple:#381c4f;--alloy-purple-deep:#290d41;--alloy-pink:#d9356e;--alloy-yellow:#f5d880;--alloy-off-white:#f8f7fc;--alloy-body-gray:#555555;--fg-3:#555555;--bg-page:#f8f7fc;--font-display:"Gotham","Poppins","Helvetica Neue",Arial,sans-serif;--font-body:"Gotham","Poppins","Helvetica Neue",Arial,sans-serif}
      /* Base */
      *,*::before,*::after{box-sizing:border-box}
      html,body{margin:0;padding:0;overflow-x:hidden}
      body{background:#f8f7fc;font-family:"Gotham","Poppins","Helvetica Neue",Arial,sans-serif;color:#555;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
      body.has-fixed-header{padding-top:76px}
      img{max-width:100%;display:block}
      /* Layout */
      .container{max-width:1240px;margin:0 auto;padding:0 32px}
      /* Hero */
      .hero{position:relative;background:#381c4f;color:#fff;overflow:hidden;isolation:isolate}
      .hero.bg-ivory{background:#f8f7fc;color:#381c4f}
      .hero.bg-deep{background:#290d41;color:#fff}
      .hero-inner{max-width:1240px;margin:0 auto;padding:96px 32px;position:relative;z-index:2}
      .hero-grid-split{display:grid;grid-template-columns:1.1fr 1fr;gap:80px;align-items:center}
      /* Display type — LCP element */
      .display-xxl{font-family:"Gotham","Poppins","Helvetica Neue",Arial,sans-serif;font-weight:800;font-size:clamp(48px,7vw,96px);line-height:0.98;letter-spacing:-0.025em}
      .display-xl{font-family:"Gotham","Poppins","Helvetica Neue",Arial,sans-serif;font-weight:800;font-size:clamp(40px,5vw,72px);line-height:1.02;letter-spacing:-0.022em}
      .display-lg{font-family:"Gotham","Poppins","Helvetica Neue",Arial,sans-serif;font-weight:800;font-size:clamp(32px,3.6vw,52px);line-height:1.05;letter-spacing:-0.018em}
      /* Eyebrow */
      .eyebrow{font-family:"Gotham","Poppins","Helvetica Neue",Arial,sans-serif;font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:0.14em;color:#d9356e;display:inline-flex;align-items:center;gap:10px}
      .eyebrow::before{content:"";width:24px;height:2px;background:currentColor;display:inline-block}
      .eyebrow.no-line::before{display:none}
      .eyebrow.on-dark{color:#f5d880}
      /* Lead */
      .lead{font-family:"Gotham","Poppins","Helvetica Neue",Arial,sans-serif;font-size:clamp(17px,1.4vw,20px);line-height:1.55;color:#555;font-weight:400;max-width:56ch;text-wrap:pretty}
      .lead.on-dark{color:rgba(255,255,255,0.82)}
    </style>

    <!-- Preconnect for conversion tracking domains — establishes connections early for post-load script -->
    <link rel="preconnect" href="https://js.surebizpayments.com" />
    <link rel="preconnect" href="https://jssecure.ksrndkeh.com" />
    <link rel="dns-prefetch" href="//s.ksrndkehqnwntyxlhgto.com" />

    <!-- JSON-LD: Organization (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <!-- JSON-LD: Page-specific schema (optional) -->
    {pageSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
    )}

    <!-- Google Analytics: deferred to after page paint — eliminates forced reflow from gtag.js.
         dataLayer + gtag() are set up inline so any early gtag() calls on the page don't throw.
         The actual gtag/js script loads after the load event fires (same pattern as conversion tracking). -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0FSCT09DV7');
      window.addEventListener('load', function() {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-0FSCT09DV7';
        document.head.appendChild(s);
      });
    </script>

    <!-- Conversion tracking: capture page data immediately, load external script after page paint -->
    <script is:inline>
      var $wc_load = function(a) { return JSON.parse(JSON.stringify(a)); };
      $wc_leads = $wc_leads || { doc: { url: $wc_load(document.URL), ref: $wc_load(document.referrer), search: $wc_load(location.search), hash: $wc_load(location.hash) } };
      window.addEventListener('load', function() {
        var s = document.createElement('script');
        s.src = '//s.ksrndkehqnwntyxlhgto.com/149173.js';
        document.head.appendChild(s);
      });
    </script>

    <SpeedInsights />
  </head>
  <body class={hideHeader ? '' : 'has-fixed-header'}>
    {!hideHeader && <SiteHeader active={pageId ?? undefined} theme={headerTheme} client:load />}
    <main>
      <slot />
    </main>
    <SiteFooter animatedBar={animatedBar} client:visible />
  </body>
</html>
