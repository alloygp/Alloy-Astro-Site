{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "allowJs": true,
    "noUnusedParameters": false,
    "noUnusedLocals": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
